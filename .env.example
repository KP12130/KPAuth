# KP Auth - Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://your-kp-auth.onrender.com

# JWT Secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email@example.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=no-reply@yourdomain.com
SMTP_FROM_NAME=KP Auth

# Database (SQLite file path - for Render use /tmp or a persistent disk)
DB_PATH=./kp-auth.db
